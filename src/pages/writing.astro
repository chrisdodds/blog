---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout title="Writing - Chris Dodds">
  <main id="main-content">
    <Header />

    <section class="writing">
      <h2>Necessary Cuts</h2>
      <p>
        My debut novella, winner of the 2026 <a
          href="https://sites.miamioh.edu/miami-university-press/"
          target="_blank"
          rel="noopener noreferrer">Miami University Press</a
        > Novella Prize. Forthcoming. You can <a
          href="https://necessarycuts.com"
          target="_blank"
          rel="noopener noreferrer">read an interactive fragment</a
        > while you wait.
      </p>

      <h2>Short Fiction</h2>
      <ul>
        <li>
          <a href="https://mrbullbull.com/newbull/flash-fiction/dog-2/" target="_blank" rel="noopener noreferrer"><em>Dog</em></a> — BULL, 2026
        </li>
      </ul>

      <h2>Nonfiction</h2>
      <ul>
        <li>
          <em>Unknown Caller</em> — <a href="https://pitheadchapel.com/" target="_blank" rel="noopener noreferrer">Pithead Chapel</a>, Vol. 15, Issue 8 (forthcoming)
        </li>
        <li>
          <a href="https://marrowmagazine.com/the-desert/" target="_blank" rel="noopener noreferrer"><em>The Desert</em></a> — Marrow Magazine, Issue 16
        </li>
      </ul>

      <h2>Recognition</h2>
      <ul>
        <li>
          Longlist, <a
            href="https://fracturedlit.com/fractured-lit-2025-elsewhere-prize-judged-by-jemimah-wei-longlist/"
            target="_blank"
            rel="noopener noreferrer">Fractured Lit 2025 Elsewhere Prize</a
          >
        </li>
      </ul>

    </section>
  </main>
</Layout>

<style>
  .writing h2 {
    font-size: 1.5rem;
    margin: 2rem 0 1rem 0;
  }

  .writing h2:first-child {
    margin-top: 0;
  }

  .writing p,
  .writing ul {
    font-size: 1.125rem;
    line-height: 1.7;
    margin: 0;
  }

  .writing ul {
    padding-left: 1.5rem;
  }

  .writing li {
    margin-bottom: 0.75rem;
  }

  .writing blockquote {
    border-left: 3px solid #ddd;
    padding-left: 1.25em;
    margin: 0.5em 0 0 0;
    color: #555;
    font-style: italic;
    font-size: 1rem;
  }
</style>
